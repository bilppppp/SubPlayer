# ── SubPlayer Nginx 反代配置 ─────────────────────────────────────────
# 在宝塔面板「网站」→「设置」→「配置文件」中添加以下内容。
# 将 your-domain.com 替换为实际域名。
# SSL 由宝塔面板自动配置（Let's Encrypt 免费证书）。

server {
    listen 80;
    listen 443 ssl http2;
    server_name your-domain.com;

    # SSL — 宝塔自动管理，以下路径由宝塔生成
    # ssl_certificate      /www/server/panel/vhost/cert/your-domain.com/fullchain.pem;
    # ssl_certificate_key  /www/server/panel/vhost/cert/your-domain.com/privkey.pem;

    # ── API 反代 → Gateway ──────────────────────────────────────────
    location /api/ {
        proxy_pass http://127.0.0.1:8080;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;

        # 大文件上传支持
        client_max_body_size 500M;
        proxy_read_timeout  300s;
        proxy_send_timeout  300s;

        # WebSocket 支持（未来流式识别用）
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }

    # ── 健康检查 ────────────────────────────────────────────────────
    location = /health {
        proxy_pass http://127.0.0.1:8080/api/health;
    }

    # ── 前端由 Vercel 托管，其余请求 301 到 Vercel ──────────────────
    # 如果前端也部署在同一服务器，取消注释以下配置：
    # location / {
    #     root /www/wwwroot/subplayer/apps/web/out;
    #     try_files $uri $uri.html $uri/ /index.html;
    # }
}
